<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FFF3F9"
                android:centerColor="#F8F7FC"
                android:endColor="#EEF8FF" />
        </shape>
    </item>
    <item
        android:width="144dp"
        android:height="144dp"
        android:gravity="center">
        <bitmap
            android:src="@drawable/aetherx_app_icon"
            android:gravity="fill" />
    </item>
</layer-list>
