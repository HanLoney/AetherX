{
  "name": "aetherx-desktop",
  "version": "1.2.4",
  "description": "AetherX modular personal assistant desktop client",
  "main": "main.js",
  "author": "Xuanxiaotech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HanLoney/AetherX.git",
    "directory": "frontend/desktop"
  },
  "bugs": "https://github.com/HanLoney/AetherX/issues",
  "homepage": "https://github.com/HanLoney/AetherX#readme",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "dist": "npm run dist:installer && npm run dist:portable",
    "dist:installer": "electron-builder --win nsis --config.artifactName=\"${productName}-安装版-${version}-${arch}.${ext}\"",
    "dist:portable": "electron-builder --win portable --config.artifactName=\"${productName}-免安装版-${version}-${arch}.${ext}\""
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.xuanxiaotech.todo",
  "productName": "AetherX",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "hub-runtime.js",
      "sync-runtime.js",
      "api-client.js",
      "auth-store.js",
      "preload.js",
      "auth.html",
      "auth.css",
      "auth.js",
      "home.html",
      "home.css",
      "app-shell.css",
      "clock.js",
      "home.js",
      "ai-providers.js",
      "tool-registry.js",
      "todo-tools.js",
      "module-settings.js",
      "xuan-mood.js",
      "reminder-composer.js",
      "reminder-engine.js",
      "journal-writer.js",
      "dream-writer.js",
      "memory-tools.js",
      "journal-tools.js",
      "album-tools.js",
      "dream-tools.js",
      "album-writer.js",
      "markdown-renderer.js",
      "modules.html",
      "modules.css",
      "modules.js",
      "memory.html",
      "memory.css",
      "memory.js",
      "album.html",
      "album.css",
      "album.js",
      "album-pager.js",
      "dream.html",
      "dream.css",
      "dream.js",
      "image-generator.html",
      "image-generator.css",
      "image-generator.js",
      "profile.html",
      "profile.css",
      "profile.js",
    "journal-pager.js",
    "gallery-layout.js",
    "growth-language.js",
      "avatar-cropper.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "app-icon-rounded.png"
    ],
    "extraResources": [
      {
        "from": "../../backend",
        "to": "backend",
        "filter": [
          "src/**/*",
          "package.json",
          "README.md"
        ]
      }
    ],
    "win": {
      "icon": "app-icon-rounded.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AetherX"
    }
  }
}
