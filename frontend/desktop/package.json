{
  "name": "aetherx-desktop",
  "version": "1.2.4",
  "description": "AetherX modular personal assistant desktop client",
  "main": "main.js",
  "author": "Xuanxiaotech",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "npm run dist:installer && npm run dist:portable",
    "dist:installer": "electron-builder --win nsis --config.artifactName=\"${productName}-安装版-${version}-${arch}.${ext}\"",
    "dist:portable": "electron-builder --win portable --config.artifactName=\"${productName}-免安装版-${version}-${arch}.${ext}\""
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.xuanxiaotech.todo",
  "productName": "AetherX",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "api-client.js",
      "preload.js",
      "home.html",
      "home.css",
      "app-shell.css",
      "home.js",
      "ai-providers.js",
      "tool-registry.js",
      "todo-tools.js",
      "module-settings.js",
      "xuan-mood.js",
      "reminder-composer.js",
      "reminder-engine.js",
      "journal-writer.js",
      "memory-tools.js",
      "journal-tools.js",
      "markdown-renderer.js",
      "modules.html",
      "modules.css",
      "modules.js",
      "memory.html",
      "memory.css",
      "memory.js",
      "profile.html",
      "profile.css",
      "profile.js",
      "avatar-cropper.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "app-icon-rounded.png"
    ],
    "win": {
      "icon": "app-icon-rounded.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AetherX"
    }
  }
}
